<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#1E293B">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="StudyBuddy"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find, create, and join study sessions"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="18dp"
            android:hint="Search course or topic"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#111827"
            android:textColorHint="#6B7280"
            android:background="@drawable/bg_search" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSessions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F4F6FB"
        android:padding="16dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:weightSum="4">

        <Button
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Home"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB" />

        <Button
            android:id="@+id/btnCreateSession"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Create"
            android:textAllCaps="false"
            android:textColor="#2563EB"
            android:backgroundTint="#DBEAFE" />

        <Button
            android:id="@+id/btnNearbySessions"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Nearby"
            android:textAllCaps="false"
            android:textColor="#2563EB"
            android:backgroundTint="#DBEAFE" />

        <Button
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Profile"
            android:textAllCaps="false"
            android:textColor="#2563EB"
            android:backgroundTint="#DBEAFE" />

    </LinearLayout>

</LinearLayout>
